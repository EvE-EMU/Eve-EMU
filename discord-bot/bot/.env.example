# =============================================================================
# EVE-EMU Discord bot — copy to ".env" in this folder (same dir as eve_mining_timer_bot.py).
# python-dotenv loads .env when you run: python eve_mining_timer_bot.py
# Do not commit .env (gitignored). Use placeholders below; no spaces around "=".
# =============================================================================

# --- Required ---
EVE_DISCORD_BOT_TOKEN=

# --- Bot branding (optional; defaults: project name EVE-EMU) ---
# Discord "Playing …" activity (max 128 chars).
# EVE_DISCORD_BOT_ACTIVITY=Never Forget Nov 2, 1932 – Dec 10, 1932 GMW.
# Community Discord invite (shown in /help, /about, etc.).
# EVE_BOT_DISCORD_INVITE_URL=https://discord.gg/DHMTKsMNbp
# EVE_BOT_PRODUCT_DISPLAY_NAME=EVE-EMU
# Optional override for welcome {alliance} placeholder (defaults to product name if unset).
# EVE_BOT_ALLIANCE_DISPLAY_NAME=
# First line of /website reply (defaults to **EVE_BOT_PRODUCT_DISPLAY_NAME** if unset).
# EVE_BOT_WEBSITE_HEADLINE=
# Welcome message; placeholders: {mention} {alliance} {product}
# EVE_BOT_WELCOME_MESSAGE=Welcome {mention} to the {alliance} Discord server. ...
# Slash command descriptions (max 100 chars each; omit to use defaults from product name).
# EVE_BOT_WEBSITE_SLASH_DESCRIPTION=
# EVE_BOT_HELP_SLASH_DESCRIPTION=
# EVE_BOT_EVE_LINK_SLASH_DESCRIPTION=
# EVE_BOT_EVE_LINK_CODE_PARAMETER_DESCRIPTION=
# EVE_BOT_MINER_SLASH_GROUP_DESCRIPTION=

# --- eve-emu core (optional: /settings link|sync, /moontaxes summary, /finance) ---
# EVE_CORE_BASE_URL=https://your-core-host.example
# EVE_CORE_BOT_SECRET= (same as CORE_DISCORD_BOT_SECRET on core)
# EVE_FG_RANK_DISCORD_ROLES=fg_ceo=…;fg_member=…  (only needed for /settings sync)
# /moontaxes and /finance: same EVE_CORE_*; core must include ESI scopes (see core .env.example).
# /hr: see EVE_HR_* below.

# --- HR / member audits (/hr) ---
# EVE_HR_AUDITOR_USER_IDS=
# EVE_HR_AUDITOR_ROLE_IDS=
# EVE_HR_AUDIT_GUIDE= (optional; multiline if quoted in .env — overrides built-in policy text)
# EVE_HR_AUDIT_GUIDE_URL=
# EVE_HR_CHECKLIST=Step one;Step two;Step three

# --- Reaction role (optional) — EVE_ROLE_REACTION_MAPPINGS=Role=emoji;... ---
# Channel id from Discord URL …/channels/GUILD_ID/CHANNEL_ID. Omit MESSAGE_ID to use a pinned message in that channel.
# EVE_ROLE_REACTION_CHANNEL_ID=
# EVE_ROLE_REACTION_MESSAGE_ID=
# EVE_ROLE_REACTION_PINNED_INDEX=0
# EVE_ROLE_REACTION_MAPPINGS=EUTZ=🌍;USTZ=🌎;AUTZ=🌏
# EVE_ROLE_REACTION_ROLE_NAME=Secure Testing Group
# EVE_ROLE_REACTION_ROLE_ID=
# EVE_ROLE_REACTION_EMOJI=🍌

# --- Mining timers (pop time + inferred band from anomaly name) ---
# Minutes before respawn to DM the timer author (0 = DM at respawn time).
EVE_MINING_PING_LEAD_MINUTES=30
# Optional shared alerts channel (also posts @here there if EVE_MINING_PING_HERE=1).
# EVE_MINING_PING_CHANNEL_ID=
# EVE_MINING_PING_HERE=1
# Hours for each inferred band (defaults: 1h / 4h20m / 10h). Use float or H:MM for T2, e.g. EVE_T2_RESPAWN_HOURS=4:20
# EVE_T1_RESPAWN_HOURS=1
# EVE_T2_RESPAWN_HOURS=4:20
# EVE_T3_RESPAWN_HOURS=10
# Optional JSON state path (default: ./data/mining_timers.json)
# EVE_MINING_TIMER_STATE_FILE=

# --- Moon timer pings (optional; Google Sheet only — no EVE-EMU API token) ---
# FALSE GODS sheet tab "moon_timers" (default CSV if notify user and/or channel id is set).
# DM + channel @here together is supported if both ids are set.
# EVE_MOON_TIMERS_NOTIFY_USER_ID=
# EVE_MOON_TIMERS_CHANNEL_ID=
# EVE_MOON_TIMERS_CSV_URL=
# EVE_MOON_TIMERS_LEAD_MINUTES=30
# EVE_MOON_TIMERS_POLL_SECONDS=300
# EVE_MOON_TIMERS_PING_HERE=1
# EVE_MOON_TIMERS_PING_STATE_FILE=

# --- Slash commands (optional) ---
# Guild id for faster guild-scoped slash sync during development (omit for global-only sync).
# EVE_DISCORD_GUILD_ID=
# Comma-separated user ids allowed to use /admin without Administrator (optional).
# EVE_DISCORD_ADMIN_USER_IDS=

# --- Docker Compose: /admin restart & /admin rebuild (optional) ---
# EVE_DOCKER_ADMIN_ENABLED=1
# EVE_DOCKER_COMPOSE_DIR=/path/to/compose/project
# EVE_DOCKER_COMPOSE_SERVICE=your-service-name
# EVE_DOCKER_COMPOSE_FILE=docker-compose.yml
# EVE_DOCKER_COMPOSE_TIMEOUT_SEC=900

# --- Welcome DM / channel (optional) ---
# EVE_WELCOME_CHANNEL_ID=
# EVE_WELCOME_GUILD_ID=
# EVE_WELCOME_STATE_FILE=

# --- /website ---
# EVE_WEBSITE_URL=https://eve-emu.com/

# --- EVE-EMU API + mining bot dashboard bridge (optional) ---
# EVEEMU_API_BASE_URL=https://your-api.example.com
# MINING_BOT_DASHBOARD_PUSH_URL=https://your-api.example.com/integrations/mining-discord-bot/heartbeat
# MINING_BOT_DASHBOARD_TOKEN=

# --- Corp projects feed (optional; needs API token + channel routing) ---
# EVE_CORP_PROJECTS_CHANNEL_ID=
# EVE_CORP_PROJECTS_GUILD_ID=
# EVE_CORP_PROJECTS_CHANNEL_NAME=corp projects
# EVE_CORP_PROJECTS_POLL_SECONDS=36000

# --- Structure timer board posts (optional) ---
# EVE_STRUCTURE_TIMER_CHANNEL_ID=
# EVE_STRUCTURE_TIMER_POLL_SECONDS=300

# --- Market / stocker alerts (optional) ---
# EVE_MARKET_WATCH_CHANNEL_ID=
# EVE_MARKET_WATCH_POLL_SECONDS=600

# --- Account notification DMs (optional) ---
# EVE_ACCOUNT_NOTIFY_POLL_SECONDS=3600

# --- Buyback admin channel alerts (optional) ---
# EVE_BUYBACK_ADMIN_ALERT_CHANNEL_ID=
# EVE_BUYBACK_ADMIN_ALERT_POLL_SECONDS=300

# --- /mumble GIF (optional path to push-to-talk help image) ---
# EVE_MUMBLE_HELP_IMAGE=

# --- Belt ping images (optional; override default filenames next to the bot) ---
# EVE_BELT_PING_IMAGE_LARGE_VELDSPAR_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_MORDUNIUM_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_KYLIXIUM_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_UEGANITE_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_GRIEMEER_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_HEZORIME_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_NOCXITE_DEPOSIT=

# --- Solar system autocomplete (/miner timer) — WoMP defaults ---
# ESI GetSovereigntyMap: https://developers.eveonline.com/api-explorer#/operations/GetSovereigntyMap
# Comment EVE_SYSTEM_NAMES_SOV_ALLIANCE_ID for full-universe autocomplete from mapSolarSystems.
EVE_SYSTEM_NAMES_SOV_ALLIANCE_ID=99010468
EVE_SYSTEM_NAMES_SOV_REFRESH_HOURS=24
# EVE_SYSTEM_NAMES_SOV_ALLIANCE_NAME=Weapons Of Mass Production.
# EVE_SYSTEM_NAMES_CSV_PATH=
# EVE_SYSTEM_NAMES_CSV_URL=https://www.fuzzwork.co.uk/dump/latest/mapSolarSystems.csv

# --- Discord login backoff (crash loop / bad token protection) ---
# EVE_DISCORD_LOGIN_BACKOFF_BASE_SEC=30
# EVE_DISCORD_LOGIN_BACKOFF_MAX_SEC=900
