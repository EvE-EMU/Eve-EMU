# =============================================================================
# EVE-EMU Discord bot — copy this file to ".env" in this folder
# (same directory as eve_mining_timer_bot.py).
#
# python-dotenv loads ".env" when you run: python eve_mining_timer_bot.py
# (requires: pip install -r ../requirements.txt)
#
# Do not commit ".env" (gitignored). No spaces around "=" in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
# Bot token from Discord Developer Portal → Your App → Bot → Token
EVE_DISCORD_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Branding & presence (optional)
# -----------------------------------------------------------------------------
# "Playing …" status line (Discord max 128 characters).
# EVE_DISCORD_BOT_ACTIVITY=Never Forget Nov 2, 1932 – Dec 10, 1932 GMW.

# Invite URL for /help, /about, and similar (default is the EVE-EMU community server).
# EVE_BOT_DISCORD_INVITE_URL=https://discord.gg/DHMTKsMNbp

# Display name in bot messages (default EVE-EMU).
# EVE_BOT_PRODUCT_DISPLAY_NAME=EVE-EMU

# Description of the /miner slash command group (max 100 characters for Discord).
# EVE_BOT_MINER_SLASH_GROUP_DESCRIPTION=Mining timer tools

# -----------------------------------------------------------------------------
# Slash command sync (optional, development)
# -----------------------------------------------------------------------------
# If set, slash commands sync to this guild first (faster than global propagation).
# Leave unset for global-only registration.
# EVE_DISCORD_GUILD_ID=

# Comma-separated Discord user ids allowed to use /admin without Administrator (optional).
# If unset, only members with Administrator can use /admin. Server may need Integration permission overrides.
# EVE_DISCORD_ADMIN_USER_IDS=

# -----------------------------------------------------------------------------
# Reaction role (optional) — multiple emojis on one post → roles (add/remove with reaction)
# -----------------------------------------------------------------------------
# Channel: https://discord.com/channels/1502802036033454080/1503769056489111652 (guild / channel id from URL).
# Leave EVE_ROLE_REACTION_MESSAGE_ID unset to use a pinned message in that channel (see EVE_ROLE_REACTION_PINNED_INDEX).
# Bot needs **Manage Roles**; bot role above every granted role.
EVE_ROLE_REACTION_CHANNEL_ID=1503769056489111652
# EVE_ROLE_REACTION_MESSAGE_ID=
# Which pinned message if several (0 = first in Discord’s pins list; increase if the wrong pin is chosen).
# EVE_ROLE_REACTION_PINNED_INDEX=0
# Globe emojis (Discord :earth_africa: / :earth_americas: / :earth_asia:) → EUTZ / USTZ / AUTZ:
EVE_ROLE_REACTION_MAPPINGS=EUTZ=🌍;USTZ=🌎;AUTZ=🌏
# If EVE_ROLE_REACTION_MAPPINGS is unset, legacy single rule applies (default 🍌 → Secure Testing Group):
# EVE_ROLE_REACTION_ROLE_NAME=Secure Testing Group
# EVE_ROLE_REACTION_ROLE_ID=
# EVE_ROLE_REACTION_EMOJI=🍌

# -----------------------------------------------------------------------------
# /admin restart & /admin rebuild — Docker Compose (optional)
# -----------------------------------------------------------------------------
# Host must have `docker` on PATH. Process should run on the Docker host (or have access to the daemon).
# EVE_DOCKER_ADMIN_ENABLED=1
# Absolute path to the directory containing docker-compose.yml (or the dir you use with -f).
# EVE_DOCKER_COMPOSE_DIR=/opt/your-stack
# Compose service name to restart/rebuild (e.g. discord-bot).
# EVE_DOCKER_COMPOSE_SERVICE=discord-bot
# Optional compose file if not docker-compose.yml (relative to EVE_DOCKER_COMPOSE_DIR or absolute).
# EVE_DOCKER_COMPOSE_FILE=docker-compose.yml
# Timeout seconds for docker compose commands (default 900).
# EVE_DOCKER_COMPOSE_TIMEOUT_SEC=900

# -----------------------------------------------------------------------------
# Mining anomaly timers (/miner timer, /miner respawns)
# -----------------------------------------------------------------------------
# Minutes before respawn to DM the user who set the timer (0 = DM at respawn).
EVE_MINING_PING_LEAD_MINUTES=30

# Optional: text channel id for shared belt alerts. If set, the bot also posts there
# (with optional @here — see EVE_MINING_PING_HERE). Author still gets a DM.
# EVE_MINING_PING_CHANNEL_ID=

# Include @here in the mining alerts channel (only if EVE_MINING_PING_CHANNEL_ID is set): 1/true or 0/false (default 1).
# EVE_MINING_PING_HERE=1

# Inferred band lengths after pop (hours). Use a float or H:MM for T2, e.g. 4:20
# EVE_T1_RESPAWN_HOURS=1
# EVE_T2_RESPAWN_HOURS=4:20
# EVE_T3_RESPAWN_HOURS=10

# Persisted timer state (default ./data/mining_timers.json).
# EVE_MINING_TIMER_STATE_FILE=

# -----------------------------------------------------------------------------
# Moon timer pings (optional — Google Sheet CSV, no API token)
# -----------------------------------------------------------------------------
# Optional: Discord user id for moon alerts by DM (plain text, no @here).
# EVE_MOON_TIMERS_NOTIFY_USER_ID=

# Text channel id for moon pings (optional @here — see EVE_MOON_TIMERS_PING_HERE).
# If set and EVE_MOON_TIMERS_CSV_URL is empty, the bot uses the default public sheet CSV (see module docstring).
# You can set NOTIFY_USER_ID and CHANNEL_ID together: DM + channel @here.
# EVE_MOON_TIMERS_CHANNEL_ID=

# Override the moon CSV URL (tab must be readable without auth).
# EVE_MOON_TIMERS_CSV_URL=

# Minutes before "Next Timer" to ping (default 30).
# EVE_MOON_TIMERS_LEAD_MINUTES=30

# Poll interval in seconds (default 300, minimum enforced in code: 120).
# EVE_MOON_TIMERS_POLL_SECONDS=300

# Include @here in moon pings (channel mode only): 1/true or 0/false (default 1).
# EVE_MOON_TIMERS_PING_HERE=1

# Dedupe file for moon pings (default ./data/moon_timer_pings.json).
# EVE_MOON_TIMERS_PING_STATE_FILE=

# -----------------------------------------------------------------------------
# /mumble attachment (optional)
# -----------------------------------------------------------------------------
# Path to GIF shown with /mumble (defaults to mumble_shout_whisper.gif if present).
# EVE_MUMBLE_HELP_IMAGE=

# -----------------------------------------------------------------------------
# Mining ping images (optional — belt-specific images next to the bot)
# -----------------------------------------------------------------------------
# EVE_BELT_PING_IMAGE_LARGE_VELDSPAR_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_MORDUNIUM_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_KYLIXIUM_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_UEGANITE_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_GRIEMEER_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_HEZORIME_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_NOCXITE_DEPOSIT=

# -----------------------------------------------------------------------------
# /miner timer autocomplete — solar systems (WoMP defaults for this bot)
# -----------------------------------------------------------------------------
# ESI sovereignty map (GetSovereigntyMap → GET /sovereignty/map/):
# https://developers.eveonline.com/api-explorer#/operations/GetSovereigntyMap
# Comment out EVE_SYSTEM_NAMES_SOV_ALLIANCE_ID to use the full mapSolarSystems list instead.
EVE_SYSTEM_NAMES_SOV_ALLIANCE_ID=99010468
EVE_SYSTEM_NAMES_SOV_REFRESH_HOURS=24
# Optional: resolve by exact ESI alliance name instead of id (do not set both id and name unless they match).
# EVE_SYSTEM_NAMES_SOV_ALLIANCE_NAME=Weapons Of Mass Production.
# Local CSV (optional; otherwise Fuzzwork URL below is fetched for ID→name and as fallback).
# EVE_SYSTEM_NAMES_CSV_PATH=
# EVE_SYSTEM_NAMES_CSV_URL=https://www.fuzzwork.co.uk/dump/latest/mapSolarSystems.csv

# -----------------------------------------------------------------------------
# Discord login backoff (optional — bad token / crash loop protection)
# -----------------------------------------------------------------------------
# EVE_DISCORD_LOGIN_BACKOFF_BASE_SEC=30
# EVE_DISCORD_LOGIN_BACKOFF_MAX_SEC=900
