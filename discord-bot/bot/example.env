# =============================================================================
# EvE-EMU Discord bot — copy to ".env" in this folder (same dir as eve_mining_timer_bot.py).
# python-dotenv loads .env when you run: python eve_mining_timer_bot.py
# Do not commit .env (gitignored). Use placeholders below; no spaces around "=".
# =============================================================================

# --- Required ---
EVE_DISCORD_BOT_TOKEN=

# --- Mining timers (pop time + inferred band from anomaly name) ---
# Minutes before respawn to @here ping (0 = ping at respawn time).
EVE_MINING_PING_LEAD_MINUTES=30
# Hours for each inferred band (defaults: 1h / 4h20m / 10h). Use float or H:MM for T2, e.g. EVE_T2_RESPAWN_HOURS=4:20
# EVE_T1_RESPAWN_HOURS=1
# EVE_T2_RESPAWN_HOURS=4:20
# EVE_T3_RESPAWN_HOURS=10
# Optional JSON state path (default: ./data/mining_timers.json)
# EVE_MINING_TIMER_STATE_FILE=

# --- Moon timer pings (optional; Google Sheet only — no EvE-EMU API token) ---
# FALSE GODS sheet tab "moon_timers" (default CSV if channel id is set).
# EVE_MOON_TIMERS_CHANNEL_ID=
# EVE_MOON_TIMERS_CSV_URL=
# EVE_MOON_TIMERS_LEAD_MINUTES=30
# EVE_MOON_TIMERS_POLL_SECONDS=300
# EVE_MOON_TIMERS_PING_HERE=1
# EVE_MOON_TIMERS_PING_STATE_FILE=

# --- Slash commands (optional) ---
# Guild id for faster guild-scoped slash sync during development (omit for global-only sync).
# EVE_DISCORD_GUILD_ID=

# --- Welcome DM / channel (optional) ---
# EVE_WELCOME_CHANNEL_ID=
# EVE_WELCOME_GUILD_ID=
# EVE_WELCOME_STATE_FILE=

# --- /website ---
# EVE_WEBSITE_URL=https://eve-emu.com/

# --- EvE-EMU API + mining bot dashboard bridge (optional) ---
# EVEEMU_API_BASE_URL=https://your-api.example.com
# MINING_BOT_DASHBOARD_PUSH_URL=https://your-api.example.com/integrations/mining-discord-bot/heartbeat
# MINING_BOT_DASHBOARD_TOKEN=

# --- Corp projects feed (optional; needs API token + channel routing) ---
# EVE_CORP_PROJECTS_CHANNEL_ID=
# EVE_CORP_PROJECTS_GUILD_ID=
# EVE_CORP_PROJECTS_CHANNEL_NAME=corp projects
# EVE_CORP_PROJECTS_POLL_SECONDS=36000

# --- Structure timer board posts (optional) ---
# EVE_STRUCTURE_TIMER_CHANNEL_ID=
# EVE_STRUCTURE_TIMER_POLL_SECONDS=300

# --- Market / stocker alerts (optional) ---
# EVE_MARKET_WATCH_CHANNEL_ID=
# EVE_MARKET_WATCH_POLL_SECONDS=600

# --- Account notification DMs (optional) ---
# EVE_ACCOUNT_NOTIFY_POLL_SECONDS=3600

# --- Buyback admin channel alerts (optional) ---
# EVE_BUYBACK_ADMIN_ALERT_CHANNEL_ID=
# EVE_BUYBACK_ADMIN_ALERT_POLL_SECONDS=300

# --- !mumble GIF (optional path to push-to-talk help image) ---
# EVE_MUMBLE_HELP_IMAGE=

# --- Belt ping images (optional; override default filenames next to the bot) ---
# EVE_BELT_PING_IMAGE_LARGE_VELDSPAR_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_MORDUNIUM_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_KYLIXIUM_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_UEGANITE_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_GRIEMEER_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_HEZORIME_DEPOSIT=
# EVE_BELT_PING_IMAGE_LARGE_NOCXITE_DEPOSIT=

# --- Solar system autocomplete (optional; default loads Fuzzwork CSV) ---
# EVE_SYSTEM_NAMES_CSV_PATH=
# EVE_SYSTEM_NAMES_CSV_URL=https://www.fuzzwork.co.uk/dump/latest/mapSolarSystems.csv

# --- Discord login backoff (crash loop / bad token protection) ---
# EVE_DISCORD_LOGIN_BACKOFF_BASE_SEC=30
# EVE_DISCORD_LOGIN_BACKOFF_MAX_SEC=900
