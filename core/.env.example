# Copy to .env (not committed). Used by pydantic-settings (CORE_* prefix).

# --- HTTP ---
CORE_PUBLIC_BASE_URL=http://localhost:8000

# --- Postgres (async SQLAlchemy) ---
# CORE_DATABASE_URL=postgresql+asyncpg://eve:eve@localhost:5432/eve_emu_core

# --- Token encryption (required before storing EVE refresh tokens in DB) ---
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CORE_TOKEN_ENCRYPTION_KEY=

# --- EVE SSO (create application at https://developers.eveonline.com/) ---
# CORE_SSO_CLIENT_ID=
# CORE_SSO_CLIENT_SECRET=
CORE_SSO_CALLBACK_URL=http://localhost:8000/v1/auth/eve/callback
# Space-separated scopes for linked characters (add scopes when enabling plugins).
CORE_SSO_SCOPES=publicData esi-characters.read_corporation_membership.v1 esi-industry.read_character_mining.v1 esi-contracts.read_character_contracts.v1 esi-assets.read_assets.v1 esi-markets.structure_markets.v1

# --- Discord bot ↔ core (same secret on bot as EVE_CORE_BOT_SECRET) ---
# CORE_DISCORD_BOT_SECRET=
# Tranquility corporation ID for "False Gods" (rank + sync-roles).
# CORE_FALSE_GODS_CORPORATION_ID=
# JSON array: [{"role_id": 98134326, "slug": "fg_director", "weight": 100}, ...] — highest weight wins (CEO always fg_ceo).
# CORE_FG_RANK_ROLES_JSON=[]
# Optional: browser redirect after successful link instead of the default HTML page.
# CORE_DISCORD_LINK_SUCCESS_URL=

# --- Moon mining tax plugin (/v1/plugins/moon-taxes/summary) ---
# ESI id for the assignee on item_exchange contracts players create (corp or character id).
# CORE_MOON_TAX_ASSIGNEE_ID=
# Optional: show suggested tax as this percent of un-contracted (adjusted-price) value (0 = omit).
# CORE_MOON_TAX_PERCENT_OF_OWED_VALUE=10
# Free text: where to contract, who to pay ISK to, Discord links, etc. (shown in API + Discord).
# CORE_MOON_TAX_PAYMENT_INSTRUCTIONS=Contract moon ore to character ID … or pay ISK to …

# --- Finance plugin (/v1/plugins/finance/*) — merged NPC + citadel sells per region ---
# Default EVE region id for /sells when the client omits region (10000002 = The Forge).
# CORE_FINANCE_DEFAULT_REGION_ID=10000002
# CORE_FINANCE_REGION_ORDERS_MAX_PAGES=10
# CORE_FINANCE_STRUCTURE_ORDERS_MAX_PAGES=3
# CORE_FINANCE_SELLS_MAX_STRUCTURE_SOURCES=40

# --- Docs ---
# CORE_OPENAPI_DOCS_ENABLED=1
